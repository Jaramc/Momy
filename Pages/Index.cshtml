@page
@model IndexModel
@using Momy.Pages
@{
    ViewData["Title"] = "Feliz cumpleaños, mamá";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Una página web elegante y emotiva dedicada a la mamá más especial del mundo. Celebra con mensajes, galerías de recuerdos y una línea de tiempo de nuestros momentos juntos.">
    <meta name="author" content="Familia">
    <meta name="keywords" content="cumpleaños, mamá, día de la madre, familia, amor">
    <meta name="theme-color" content="#E8C5D8">

    <!-- Open Graph para compartir en redes sociales -->
    <meta property="og:title" content="Feliz cumpleaños, mamá 💕">
    <meta property="og:description" content="Una página especial dedicada a la mamá más increíble del mundo">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="es_ES">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Feliz cumpleaños, mamá 💕">
    <meta name="twitter:description" content="Una página especial dedicada a mamá">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://example.com">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='75' font-size='75'>💕</text></svg>">

    <title>Feliz cumpleaños, mamá</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-b from-rose-50 to-amber-50 font-sans">
    <audio id="background-audio" autoplay loop preload="auto">
        <source src="/audio/Moon%20Love.mp3" type="audio/mpeg">
    </audio>

    <button
        id="audio-mute-toggle"
        type="button"
        class="audio-toggle fixed bottom-6 right-6 z-[1000] inline-flex h-14 w-14 items-center justify-center rounded-full border border-rose-200/70 bg-white/90 text-rose-700 shadow-lg backdrop-blur-md transition-all hover:scale-105 hover:bg-white"
        aria-label="Silenciar música"
        aria-pressed="false">
        <svg id="audio-icon-on" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5 6 9H3v6h3l5 4V5Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.5 8.5a5 5 0 0 1 0 7"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.5 5.5a9 9 0 0 1 0 13"/>
        </svg>
        <svg id="audio-icon-off" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5 6 9H3v6h3l5 4V5Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="m16 9 5 5"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 9-5 5"/>
        </svg>
    </button>

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 backdrop-blur-md bg-white/70 border-b border-rose-100/30 shadow-sm" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <a href="#" class="font-serif text-3xl font-bold text-rose-600 hover:text-rose-700 transition-colors" id="navbar-home" aria-label="Ir al inicio">
                    Mamá
                </a>

                <!-- Hamburger button for mobile -->
                <button class="md:hidden flex flex-col gap-1.5 p-2 text-gray-700 hover:text-rose-600 transition-colors" id="mobile-menu-toggle" aria-label="Abrir menú" aria-expanded="false">
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                </button>

                <ul class="hidden md:flex items-center gap-8">
                    <li><a href="#galeria" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Galería</a></li>
                    <li><a href="#cualidades" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Cualidades</a></li>
                    <li><a href="#momentos" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Momentos</a></li>
                </ul>

                <button class="bg-gradient-to-r from-rose-500 to-pink-500 text-white px-6 py-2 rounded-full hover:shadow-lg hover:from-rose-600 hover:to-pink-600 transition-all font-medium text-sm hidden md:block" id="btn-send-love" aria-label="Enviar amor">
                    Enviar amor
                </button>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-menu" class="md:hidden hidden mt-4 pb-4 border-t border-rose-100/30">
                <ul class="flex flex-col gap-4">
                    <li><a href="#galeria" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Galería</a></li>
                    <li><a href="#cualidades" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Cualidades</a></li>
                    <li><a href="#momentos" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Momentos</a></li>
                </ul>
                <button class="w-full bg-gradient-to-r from-rose-500 to-pink-500 text-white px-6 py-2 rounded-full hover:shadow-lg hover:from-rose-600 hover:to-pink-600 transition-all font-medium text-sm mt-4" id="btn-send-love-mobile" aria-label="Enviar amor">
                    Enviar amor
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20 pb-20" aria-label="Sección de bienvenida">
        <!-- Flores decorativas - Peonía izquierda superior -->
        <div class="absolute top-20 left-0 opacity-60 pointer-events-none" aria-hidden="true" style="width: 300px; height: 350px;">
            <svg viewBox="0 0 200 250" class="w-full h-full">
                <!-- Peonía rosa -->
                <g>
                    <!-- Pétalos exteriores -->
                    <ellipse cx="100" cy="80" rx="45" ry="55" fill="#E8B4C4" opacity="0.8"/>
                    <ellipse cx="140" cy="100" rx="40" ry="50" fill="#ECC4D0" opacity="0.75"/>
                    <ellipse cx="160" cy="140" rx="35" ry="45" fill="#E8B4C4" opacity="0.7"/>
                    <ellipse cx="140" cy="180" rx="40" ry="50" fill="#DFA3B8" opacity="0.75"/>
                    <ellipse cx="100" cy="200" rx="45" ry="55" fill="#D9929D" opacity="0.8"/>
                    <ellipse cx="60" cy="180" rx="40" ry="50" fill="#E8B4C4" opacity="0.75"/>
                    <ellipse cx="40" cy="140" rx="35" ry="45" fill="#ECC4D0" opacity="0.7"/>
                    <ellipse cx="60" cy="100" rx="40" ry="50" fill="#E8B4C4" opacity="0.75"/>
                    <!-- Pétalos medios -->
                    <ellipse cx="100" cy="110" rx="35" ry="45" fill="#F5D4D8" opacity="0.8"/>
                    <ellipse cx="125" cy="130" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <ellipse cx="125" cy="170" rx="30" ry="40" fill="#ECC4D0" opacity="0.75"/>
                    <ellipse cx="100" cy="190" rx="35" ry="45" fill="#E8B4C4" opacity="0.8"/>
                    <ellipse cx="75" cy="170" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <ellipse cx="75" cy="130" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <!-- Centro -->
                    <circle cx="100" cy="150" r="25" fill="#D4AF8F"/>
                    <circle cx="100" cy="150" r="18" fill="#C9975F" opacity="0.9"/>
                </g>
                <!-- Tallo y hojas -->
                <path d="M 100 200 Q 95 220, 90 240" stroke="#A8B896" stroke-width="3" fill="none" opacity="0.6"/>
                <ellipse cx="75" cy="220" rx="15" ry="25" fill="#B8C9A3" opacity="0.5" transform="rotate(-30 75 220)"/>
            </svg>
        </div>

        <!-- Flores decorativas - Peonía derecha inferior -->
        <div class="absolute bottom-0 right-0 opacity-50 pointer-events-none" aria-hidden="true" style="width: 280px; height: 320px;">
            <svg viewBox="0 0 200 250" class="w-full h-full">
                <!-- Peonía rosa -->
                <g>
                    <!-- Pétalos exteriores -->
                    <ellipse cx="100" cy="80" rx="45" ry="55" fill="#E8B4C4" opacity="0.8"/>
                    <ellipse cx="140" cy="100" rx="40" ry="50" fill="#ECC4D0" opacity="0.75"/>
                    <ellipse cx="160" cy="140" rx="35" ry="45" fill="#E8B4C4" opacity="0.7"/>
                    <ellipse cx="140" cy="180" rx="40" ry="50" fill="#DFA3B8" opacity="0.75"/>
                    <ellipse cx="100" cy="200" rx="45" ry="55" fill="#D9929D" opacity="0.8"/>
                    <ellipse cx="60" cy="180" rx="40" ry="50" fill="#E8B4C4" opacity="0.75"/>
                    <ellipse cx="40" cy="140" rx="35" ry="45" fill="#ECC4D0" opacity="0.7"/>
                    <ellipse cx="60" cy="100" rx="40" ry="50" fill="#E8B4C4" opacity="0.75"/>
                    <!-- Pétalos medios -->
                    <ellipse cx="100" cy="110" rx="35" ry="45" fill="#F5D4D8" opacity="0.8"/>
                    <ellipse cx="125" cy="130" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <ellipse cx="125" cy="170" rx="30" ry="40" fill="#ECC4D0" opacity="0.75"/>
                    <ellipse cx="100" cy="190" rx="35" ry="45" fill="#E8B4C4" opacity="0.8"/>
                    <ellipse cx="75" cy="170" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <ellipse cx="75" cy="130" rx="30" ry="40" fill="#F5D4D8" opacity="0.75"/>
                    <!-- Centro -->
                    <circle cx="100" cy="150" r="25" fill="#D4AF8F"/>
                    <circle cx="100" cy="150" r="18" fill="#C9975F" opacity="0.9"/>
                </g>
            </svg>
        </div>

        <!-- Flores loto dispersas -->
        <div class="absolute top-40 right-12 opacity-30 pointer-events-none" aria-hidden="true" style="width: 120px; height: 120px;">
            <svg viewBox="0 0 100 100" class="w-full h-full">
                <g>
                    <!-- Pétalos -->
                    <ellipse cx="50" cy="25" rx="12" ry="18" fill="#E8C5D8" opacity="0.7"/>
                    <ellipse cx="70" cy="35" rx="12" ry="18" fill="#E8C5D8" opacity="0.7" transform="rotate(60 50 50)"/>
                    <ellipse cx="75" cy="60" rx="12" ry="18" fill="#E8C5D8" opacity="0.7" transform="rotate(120 50 50)"/>
                    <ellipse cx="50" cy="75" rx="12" ry="18" fill="#E8C5D8" opacity="0.7" transform="rotate(180 50 50)"/>
                    <ellipse cx="25" cy="60" rx="12" ry="18" fill="#E8C5D8" opacity="0.7" transform="rotate(240 50 50)"/>
                    <ellipse cx="30" cy="35" rx="12" ry="18" fill="#E8C5D8" opacity="0.7" transform="rotate(300 50 50)"/>
                    <!-- Centro -->
                    <circle cx="50" cy="50" r="12" fill="#D4AF8F" opacity="0.8"/>
                </g>
            </svg>
        </div>

        <!-- Flores loto dispersas - derecha -->
        <div class="absolute top-1/3 right-20 opacity-25 pointer-events-none" aria-hidden="true" style="width: 100px; height: 100px;">
            <svg viewBox="0 0 100 100" class="w-full h-full">
                <g>
                    <!-- Pétalos -->
                    <ellipse cx="50" cy="25" rx="12" ry="18" fill="#F8D4D4" opacity="0.6"/>
                    <ellipse cx="70" cy="35" rx="12" ry="18" fill="#F8D4D4" opacity="0.6" transform="rotate(60 50 50)"/>
                    <ellipse cx="75" cy="60" rx="12" ry="18" fill="#F8D4D4" opacity="0.6" transform="rotate(120 50 50)"/>
                    <ellipse cx="50" cy="75" rx="12" ry="18" fill="#F8D4D4" opacity="0.6" transform="rotate(180 50 50)"/>
                    <ellipse cx="25" cy="60" rx="12" ry="18" fill="#F8D4D4" opacity="0.6" transform="rotate(240 50 50)"/>
                    <ellipse cx="30" cy="35" rx="12" ry="18" fill="#F8D4D4" opacity="0.6" transform="rotate(300 50 50)"/>
