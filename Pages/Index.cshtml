@page
@model IndexModel
@using Momy.Pages
@{
    ViewData["Title"] = "Feliz cumpleaños, mamá";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Una página web elegante y emotiva dedicada a la mamá más especial del mundo. Celebra con mensajes, galerías de recuerdos y una línea de tiempo de nuestros momentos juntos.">
    <meta name="author" content="Familia">
    <meta name="keywords" content="cumpleaños, mamá, día de la madre, familia, amor">
    <meta name="theme-color" content="#E8C5D8">

    <!-- Open Graph para compartir en redes sociales -->
    <meta property="og:title" content="Feliz cumpleaños, mamá 💕">
    <meta property="og:description" content="Una página especial dedicada a la mamá más increíble del mundo">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="es_ES">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Feliz cumpleaños, mamá 💕">
    <meta name="twitter:description" content="Una página especial dedicada a mamá">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://example.com">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='75' font-size='75'>💕</text></svg>">

    <title>Feliz cumpleaños, mamá</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-b from-rose-50 to-amber-50 font-sans">

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 backdrop-blur-md bg-white/70 border-b border-rose-100/30 shadow-sm" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <a href="#" class="font-serif text-3xl font-bold text-rose-600 hover:text-rose-700 transition-colors" id="navbar-home" aria-label="Ir al inicio">
                    Mamá
                </a>

                <!-- Hamburger button for mobile -->
                <button class="md:hidden flex flex-col gap-1.5 p-2 text-gray-700 hover:text-rose-600 transition-colors" id="mobile-menu-toggle" aria-label="Abrir menú" aria-expanded="false">
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                    <span class="w-6 h-0.5 bg-current transition-all"></span>
                </button>

                <ul class="hidden md:flex items-center gap-8">
                    <li><a href="#nuestra-historia" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Nuestra historia</a></li>
                    <li><a href="#galeria" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Galería</a></li>
                    <li><a href="#cualidades" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Cualidades</a></li>
                    <li><a href="#momentos" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm">Momentos</a></li>
                </ul>

                <button class="bg-gradient-to-r from-rose-500 to-pink-500 text-white px-6 py-2 rounded-full hover:shadow-lg hover:from-rose-600 hover:to-pink-600 transition-all font-medium text-sm hidden md:block" id="btn-send-love" aria-label="Enviar amor">
                    Enviar amor
                </button>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-menu" class="md:hidden hidden mt-4 pb-4 border-t border-rose-100/30">
                <ul class="flex flex-col gap-4">
                    <li><a href="#nuestra-historia" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Nuestra historia</a></li>
                    <li><a href="#galeria" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Galería</a></li>
                    <li><a href="#cualidades" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Cualidades</a></li>
                    <li><a href="#momentos" class="text-gray-700 hover:text-rose-600 transition-colors font-medium text-sm block">Momentos</a></li>
                </ul>
                <button class="w-full bg-gradient-to-r from-rose-500 to-pink-500 text-white px-6 py-2 rounded-full hover:shadow-lg hover:from-rose-600 hover:to-pink-600 transition-all font-medium text-sm mt-4" id="btn-send-love-mobile" aria-label="Enviar amor">
                    Enviar amor
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20 pb-20" aria-label="Sección de bienvenida">
        <!-- Flores decorativas -->
        <div class="absolute top-10 left-5 opacity-20 text-6xl animate-float" aria-hidden="true">
            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
        </div>
        <div class="absolute top-32 right-8 opacity-20 text-5xl animate-float" style="animation-delay: 2s;" aria-hidden="true">
            <svg class="w-14 h-14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </div>
        <div class="absolute bottom-20 left-10 opacity-15 text-4xl animate-float" style="animation-delay: 4s;" aria-hidden="true">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
        </div>

        <div class="text-center max-w-2xl mx-auto px-4 relative z-10">
            <div class="inline-block mb-6 animate-bounce" style="animation-duration: 2s;">
                <svg class="w-16 h-16 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </div>

            <h1 class="font-serif text-6xl md:text-7xl text-rose-900 mb-6 font-bold leading-tight animate-fadeIn">
                Feliz cumpleaños,<br> mamá
            </h1>

            <p class="text-gray-700 text-lg md:text-xl mb-10 leading-relaxed max-w-xl mx-auto font-light">
                Y feliz Día de las Madres a la mujer más especial de mi vida.
            </p>

            <button class="bg-gradient-to-r from-rose-500 to-pink-500 text-white px-8 py-4 rounded-full hover:shadow-2xl hover:from-rose-600 hover:to-pink-600 transition-all font-serif text-lg font-semibold" id="btn-message" aria-label="Ver mensaje para mamá">
                Ver mi mensaje para ti
            </button>
        </div>
    </section>

    <!-- Tarjeta de Mensaje Emocional -->
    <section id="mensaje" class="py-20 px-4">
        <div class="max-w-2xl mx-auto">
            <div class="bg-gradient-to-br from-rose-100 via-pink-50 to-amber-50 rounded-3xl p-8 md:p-12 shadow-2xl border border-rose-200/50 relative overflow-hidden group hover:shadow-3xl transition-all duration-300">
                <!-- Decoraciones en esquinas -->
                <div class="absolute top-4 right-4 text-4xl opacity-30">🌹</div>
                <div class="absolute bottom-4 left-4 text-4xl opacity-30">🌸</div>

                <div class="relative z-10">
                    <h2 class="font-serif text-4xl md:text-5xl text-rose-900 mb-8 text-center font-bold">
                        Un mensaje para ti
                    </h2>

                    <div class="space-y-6 text-gray-800 text-lg leading-relaxed font-light">
                        <p class="italic text-center text-xl text-rose-700 font-serif">
                            "Mamá, no hay palabras suficientes para agradecerte todo lo que has hecho por mí."
                        </p>

                        <p>
                            Tu amor ha sido la brújula que me guía en los momentos oscuros, el refugio seguro donde siempre encuentro paz.
                            Cada consejo, cada gesto de cuidado, cada sacrificio silencioso ha moldeado quién soy hoy.
                        </p>

                        <p>
                            Te admiro por tu fortaleza inquebrantable, por tu capacidad de amar sin límites,
                            por ser el corazón que nos mantiene unidos como familia. Eres mi inspiración diaria,
                            mi ejemplo de bondad y dedicación.
                        </p>

                        <p>
                            En cada logro que alcancemos, en cada momento de felicidad, en cada sueño cumplido,
                            estarás ahí porque construiste los cimientos sobre los que hemos crecido.
                        </p>

                        <p>
                            Hoy celebramos tu vida, tu esencia, tu luz. Celebramos a la mujer más especial del mundo.
                        </p>

                        <p class="pt-4 text-center font-serif text-2xl text-rose-800">
                            Con amor infinito,<br>
                            <span class="text-lg">Tu hijo/a</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sección Galería de Momentos -->
    <section id="galeria" class="py-20 px-4 bg-white/50" aria-label="Galería de momentos">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-serif text-5xl md:text-6xl text-center text-rose-900 mb-4 font-bold">
                Momentos que guardo en mi corazón
            </h2>
            <p class="text-center text-gray-600 mb-16 text-lg font-light">
                Recuerdos que vivirán para siempre en mi corazón
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Imagen grande izquierda -->
                <div class="md:col-span-1 md:row-span-2 group cursor-pointer" role="button" tabindex="0" aria-label="Abrir galería de fotos">
                    <div class="relative rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 h-96 md:h-full">
                        <img src="@Model.Memories.FirstOrDefault()?.ImageUrl ?? 'https://images.unsplash.com/photo-1511632765486-a01980e01a18?w=600&h=800&fit=crop'"
                             alt="Momento especial" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-all duration-300"></div>
                        <div class="absolute bottom-6 left-6 right-6 text-white">
                            <h3 class="font-serif text-2xl font-bold">@Model.Memories.FirstOrDefault()?.Title</h3>
                        </div>
                        <div class="absolute top-6 right-6 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                            <svg class="w-8 h-8 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                        </div>
                    </div>
                </div>

                <!-- Imágenes pequeñas derecha -->
                @foreach (var memory in Model.Memories.Skip(1).Take(2))
                {
                    <div class="group cursor-pointer" role="button" tabindex="0" aria-label="Foto de @memory.Title">
                        <div class="relative rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 h-40 md:h-auto">
                            <img src="@memory.ImageUrl" alt="@memory.Title"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-all duration-300"></div>
                            <div class="absolute bottom-4 left-4 right-4 text-white">
                                <h3 class="font-serif text-lg font-bold">@memory.Title</h3>
                            </div>
                            <div class="absolute top-4 right-4 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                                <svg class="w-6 h-6 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Banner Emocional -->
    <section class="relative py-20 overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center opacity-40"
             style="background-image: url('https://images.unsplash.com/photo-1490633874519-7b5a9d1f3c00?w=1200&h=300&fit=crop');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-rose-600/50 to-pink-600/50"></div>

        <div class="relative z-10 text-center py-16">
            <div class="inline-block mb-8 animate-pulse">
                <svg class="w-16 h-16 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h2 class="font-serif text-6xl md:text-7xl text-white font-bold mb-6">
                Tu luz ilumina todo
            </h2>
            <p class="text-white/90 text-xl max-w-xl mx-auto font-light">
                Eres la brújula que nos guía, el corazón que nos une, el amor que nos transforma.
            </p>
        </div>
    </section>

    <!-- Sección de Cualidades -->
    <section id="cualidades" class="py-20 px-4" aria-label="Cualidades admirables">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-serif text-5xl md:text-6xl text-center text-rose-900 mb-4 font-bold">
                Cualidades que admiro en ti
            </h2>
            <p class="text-center text-gray-600 mb-16 text-lg font-light">
                Las razones por las que eres especial
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                @foreach (var quality in Model.Qualities)
                {
                    <div class="bg-white rounded-2xl p-8 border-2 border-rose-100 shadow-lg hover:shadow-xl hover:border-rose-300 transition-all duration-300 group">
                        <div class="inline-block mb-4 p-3 bg-rose-100 rounded-lg group-hover:scale-110 transition-transform duration-300">
                            @switch(quality.Title)
                            {
                                case "Amorosa":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                    break;
                                case "Fuerte":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M13 6v10h7V6h-7zM6 6v10h7V6H6zM3 3h18v4H3V3z"/></svg>
                                    break;
                                case "Dulce":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                                    break;
                                case "Valiente":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    break;
                                case "Única":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.39 7.36h7.75l-6.27 4.56 2.39 7.37-6.27-4.56-6.27 4.56 2.39-7.37-6.27-4.56h7.75L12 2z"/></svg>
                                    break;
                                case "Inspiración":
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg>
                                    break;
                                default:
                                    <svg class="w-8 h-8 text-rose-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    break;
                            }
                        </div>
                        <h3 class="font-serif text-2xl text-rose-900 mb-4 font-bold">@quality.Title</h3>
                        <p class="text-gray-700 leading-relaxed font-light">@quality.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Sección Nuestra Historia -->
    <section id="nuestra-historia" class="py-20 px-4 bg-gradient-to-b from-rose-50/50 to-white">
        <div class="max-w-4xl mx-auto">
            <h2 class="font-serif text-5xl md:text-6xl text-center text-rose-900 mb-4 font-bold">
                Nuestra historia
            </h2>
            <p class="text-center text-gray-600 mb-16 text-lg font-light">
                Un viaje de amor a través del tiempo
            </p>

            <div class="relative">
                <!-- Línea central -->
                <div class="hidden md:block absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-rose-300 to-pink-300"></div>

                <!-- Timeline items -->
                @foreach (var (timeline, index) in Model.TimelineItems.Select((item, idx) => (item, idx)))
                {
                    var isEven = index % 2 == 0;
                    <div class="mb-16 md:mb-24 relative">
                        <!-- Punto dorado -->
                        <div class="absolute left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-6 h-6 bg-gradient-to-br from-amber-300 to-amber-400 rounded-full border-4 border-white shadow-lg"></div>

                        <!-- Contenedor alternado -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
                            @if (isEven)
                            {
                                <!-- Contenido izquierda en desktop -->
                                <div class="md:text-right">
                                    <h3 class="font-serif text-3xl text-rose-900 mb-3 font-bold">@timeline.Title</h3>
                                    <p class="text-gray-700 leading-relaxed font-light">@timeline.Description</p>
                                </div>
                                <div class="md:flex justify-end">
                                    <div class="w-32 h-32 rounded-full overflow-hidden shadow-lg border-4 border-rose-100">
                                        <img src="@timeline.ImageUrl" alt="@timeline.Title" class="w-full h-full object-cover">
                                    </div>
                                </div>
                            }
                            else
                            {
                                <!-- Contenido derecha en desktop -->
                                <div class="md:flex justify-start md:order-2">
                                    <div class="w-32 h-32 rounded-full overflow-hidden shadow-lg border-4 border-rose-100">
                                        <img src="@timeline.ImageUrl" alt="@timeline.Title" class="w-full h-full object-cover">
                                    </div>
                                </div>
                                <div class="md:order-1">
                                    <h3 class="font-serif text-3xl text-rose-900 mb-3 font-bold">@timeline.Title</h3>
                                    <p class="text-gray-700 leading-relaxed font-light">@timeline.Description</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Sección Final -->
    <section id="cierre" class="relative py-20 px-4 overflow-hidden" aria-label="Mensaje de cierre">
        <!-- Fondo decorativo -->
        <div class="absolute inset-0 bg-gradient-to-b from-pink-100 to-rose-100">
            <div class="absolute top-5 right-10 opacity-20 animate-float" aria-hidden="true">
                <svg class="w-20 h-20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </div>
            <div class="absolute bottom-10 left-8 opacity-20 animate-float" style="animation-delay: 1s;" aria-hidden="true">
                <svg class="w-20 h-20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            </div>
            <div class="absolute top-1/2 right-1/4 opacity-15 animate-float" style="animation-delay: 2s;" aria-hidden="true">
                <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center">
            <h2 class="font-serif text-5xl md:text-6xl text-rose-900 mb-6 font-bold">
                Gracias por ser mi mamá,<br> mi guía y mi mayor bendición.
            </h2>

            <p class="text-2xl md:text-3xl text-rose-700 mb-12 font-serif font-semibold">
                Te amo, mamá
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
                <button class="bg-gradient-to-r from-rose-500 to-pink-500 text-white px-8 py-4 rounded-full hover:shadow-2xl hover:from-rose-600 hover:to-pink-600 transition-all font-serif text-lg font-semibold flex items-center justify-center gap-2" id="btn-back-to-top" aria-label="Volver al inicio">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4"></path></svg>
                    Volver al inicio
                </button>
                <button class="bg-gradient-to-r from-amber-500 to-orange-500 text-white px-8 py-4 rounded-full hover:shadow-2xl hover:from-amber-600 hover:to-orange-600 transition-all font-serif text-lg font-semibold flex items-center justify-center gap-2" id="btn-download-pdf" aria-label="Descargar como PDF">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Descargar PDF
                </button>
            </div>

            <div class="text-center text-gray-700 font-light">
                <p class="text-lg mb-2">Mamá</p>
                <p class="text-rose-600 italic font-serif">Con amor, siempre y para siempre.</p>
            </div>
        </div>
    </section>

    <script src="~/js/site.js"></script>

    <!-- Galería Modal -->
    <div id="image-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" role="dialog" aria-labelledby="modal-title">
        <div class="relative bg-white rounded-3xl overflow-hidden shadow-2xl max-w-2xl w-full max-h-[90vh] flex flex-col" onclick="event.stopPropagation()">
            <!-- Botón cerrar -->
            <button id="modal-close" class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 z-10 bg-white/80 rounded-full p-2 hover:bg-white transition-all" aria-label="Cerrar galería">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <!-- Imagen -->
            <img id="modal-image" src="" alt="" class="w-full h-auto object-cover">

            <!-- Info -->
            <div class="p-6 bg-gradient-to-b from-transparent to-rose-50">
                <h3 id="modal-title" class="font-serif text-2xl text-rose-900 mb-2 font-bold"></h3>
                <p id="modal-description" class="text-gray-700 leading-relaxed font-light"></p>
            </div>

            <!-- Navegación -->
            <div class="flex gap-4 px-6 pb-6">
                <button id="modal-prev" class="flex-1 bg-rose-500 text-white px-4 py-2 rounded-full hover:bg-rose-600 transition-all" aria-label="Imagen anterior">← Anterior</button>
                <button id="modal-next" class="flex-1 bg-rose-500 text-white px-4 py-2 rounded-full hover:bg-rose-600 transition-all" aria-label="Siguiente imagen">Siguiente →</button>
            </div>
        </div>
    </div>
</body>
</html>
